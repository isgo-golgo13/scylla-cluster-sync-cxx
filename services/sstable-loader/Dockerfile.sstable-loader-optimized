# =============================================================================
# Dockerfile.sstable-loader-optimized
# Phase 2: prepared stmts + UNLOGGED BATCH + concurrent inserts
# =============================================================================

FROM ubuntu:24.04 AS builder

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake ninja-build git pkg-config \
    libssl-dev libuv1-dev zlib1g-dev \
    ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY . .

RUN cmake -S . -B build \
    -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_CXX_STANDARD=20 \
    -DSSTABLE_OPTIMIZED_INSERTS=ON \
    && cmake --build build --target sstable-loader --parallel $(nproc)

FROM ubuntu:24.04 AS runtime

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 libuv1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --system --no-create-home --shell /usr/sbin/nologin appuser

WORKDIR /app

COPY --from=builder /src/build/services/sstable-loader/sstable-loader /app/sstable-loader
COPY config/ /app/config/

RUN mkdir -p /checkpoints && chown -R appuser:appuser /app /checkpoints

USER appuser

EXPOSE 8081 9092

ENTRYPOINT ["/app/sstable-loader"]
CMD ["--config", "/app/config/sstable-loader.yaml", \
     "--indexes", "/app/config/indexes.yaml", \
     "--filter-config", "/app/config/filter-rules.yaml", \
     "--port", "8081"]
